# WarXOne Frontend - Development Environment
# Uses Vite proxy to forward /api/* to local backend (or SCF Function URLs)
VITE_AUTH_LOGIN_URL=/api/auth/login
VITE_AUTH_REGISTER_URL=/api/auth/register
VITE_AUTH_GOOGLE_URL=/api/auth/google
VITE_AUTH_REFRESH_URL=/api/auth/refresh
VITE_AUTH_LOGOUT_URL=/api/auth/logout
VITE_GAME_SAVE_URL=/api/game/save
VITE_GAME_LOAD_URL=/api/game/load
VITE_GAME_DELETE_URL=/api/game/delete
