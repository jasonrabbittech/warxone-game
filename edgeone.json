{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "./dist",
  "nodeVersion": "22.11.0",
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=31536000"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/game",
      "destination": "/",
      "statusCode": 301
    }
  ]
}
